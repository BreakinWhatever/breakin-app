generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id        String   @id @default(cuid())
  name      String
  sector    String
  size      String   @default("")
  city      String
  country   String
  website   String?
  apolloId  String?  @unique
  notes     String?

  // Scraper registry fields
  atsType       String?   // workday | greenhouse | lever | smartrecruiters | workable | ashby | custom
  careerUrl     String?
  atsConfig     Json?
  lastScrapedAt DateTime?
  active        Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts Contact[]
  events   Event[]
  offers   JobOffer[]
}

model Contact {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  companyId   String
  title       String
  email       String   @unique
  linkedinUrl String?
  apolloId    String?  @unique
  priority    Int      @default(3)
  source      String   @default("manual")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id])
  outreaches    Outreach[]
  events        Event[]
  inboundEmails InboundEmail[]
  applications  Application[]
}

model Campaign {
  id         String   @id @default(cuid())
  name       String
  targetRole String
  targetCity String
  templateId String?
  status     String   @default("draft")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template   Template?  @relation(fields: [templateId], references: [id])
  outreaches Outreach[]
}

model Outreach {
  id              String    @id @default(cuid())
  contactId       String
  campaignId      String
  status          String    @default("identified")
  lastContactDate DateTime?
  nextActionDate  DateTime?
  nextActionType  String?
  aiSuggestion    String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contact       Contact        @relation(fields: [contactId], references: [id])
  campaign      Campaign       @relation(fields: [campaignId], references: [id])
  emails        Email[]
  events        Event[]
  inboundEmails InboundEmail[]

  @@unique([contactId, campaignId])
}

model Email {
  id         String    @id @default(cuid())
  outreachId String
  type       String    @default("initial")
  subject    String
  body       String
  sentAt     DateTime?
  openedAt   DateTime?
  repliedAt  DateTime?
  status     String    @default("draft")
  createdAt  DateTime  @default(now())

  outreach Outreach @relation(fields: [outreachId], references: [id])
}

model Template {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String
  variables String   @default("[]")
  language  String   @default("fr")
  category  String   @default("initial")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns Campaign[]
}

model Setting {
  key   String @id
  value String
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  type        String   @default("interview")
  contactId   String?
  companyId   String?
  outreachId  String?
  location    String?
  notes       String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contact    Contact?  @relation(fields: [contactId], references: [id])
  company    Company?  @relation(fields: [companyId], references: [id])
  outreach   Outreach? @relation(fields: [outreachId], references: [id])
}

// --- SP2: Email Reception ---

model InboundEmail {
  id             String    @id @default(cuid())
  resendId       String?   @unique
  fromEmail      String
  fromName       String    @default("")
  toEmail        String
  subject        String
  bodyText       String?
  bodyHtml       String?
  rawWebhookData Json?
  contactId      String?
  outreachId     String?
  forwardedAt    DateTime?
  receivedAt     DateTime  @default(now())
  createdAt      DateTime  @default(now())

  contact  Contact?  @relation(fields: [contactId], references: [id])
  outreach Outreach? @relation(fields: [outreachId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String?
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())
}

// --- SP4: Job Offer Scraping ---

model JobOffer {
  id            String    @id @default(cuid())
  title         String
  company       String
  companyId     String?
  city          String
  country       String    @default("France")
  contractType  String    @default("CDI")
  description   String
  url           String    @unique
  source        String
  salary        String?
  matchScore    Int?
  matchAnalysis String?
  status        String    @default("new")
  postedAt      DateTime?
  scrapedAt     DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  companyRef   Company?      @relation(fields: [companyId], references: [id])
  applications Application[]
}

model ScrapeRun {
  id        String    @id @default(cuid())
  source    String
  status    String    @default("running")
  jobsFound Int       @default(0)
  jobsNew   Int       @default(0)
  error     String?
  startedAt DateTime  @default(now())
  endedAt   DateTime?
}

// --- SP5: Applications ---

model Application {
  id            String    @id @default(cuid())
  offerId       String?
  contactId     String?
  companyName   String
  role          String
  source        String    @default("manual")
  status        String    @default("draft")
  appliedAt     DateTime?
  coverLetterId String?
  notes         String?
  nextStep      String?
  nextStepDate  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  offer       JobOffer?    @relation(fields: [offerId], references: [id])
  contact     Contact?     @relation(fields: [contactId], references: [id])
  coverLetter CoverLetter? @relation(fields: [coverLetterId], references: [id])
}

model CoverLetter {
  id           String        @id @default(cuid())
  title        String
  body         String
  language     String        @default("fr")
  offerId      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
}

// --- SP7: Scheduled Recaps ---

model Recap {
  id        String   @id @default(cuid())
  type      String
  period    String
  content   String
  metrics   String   @default("{}")
  sentVia   String   @default("[]")
  createdAt DateTime @default(now())
}
